# Memanto Benchmark - Environment Configuration
# Copy this to .env and fill in your API keys

# Required: Get your free Moorcheh API key at https://moorcheh.ai
MOORCHEH_API_KEY=

# Required for Mem0: OpenAI API key
OPENAI_API_KEY=

# Optional: Override OpenAI base URL (for proxies like GFW)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: LLM model for accuracy evaluation
JUDGE_MODEL=gpt-4o-mini
